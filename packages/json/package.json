{
  "name": "@materialxjs/json",
  "version": "0.1.0",
  "description": "MaterialX XML to JSON converter with materialxjson and glTF KHR_texture_procedurals support",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.mjs",
      "require": "./dist/node.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "materialx",
    "gltf",
    "json",
    "3d",
    "pbr",
    "materials",
    "khronos"
  ],
  "license": "MIT",
  "dependencies": {
    "fast-xml-parser": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.7.0",
    "unbuild": "^3.5.0",
    "vitest": "^3.0.0"
  }
}
