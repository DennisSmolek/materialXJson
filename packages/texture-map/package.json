{
  "name": "@materialxjs/texture-map",
  "version": "0.1.0",
  "description": "Detect PBR material channels from texture filenames",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "materialx",
    "pbr",
    "textures",
    "materials",
    "3d"
  ],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.7.0",
    "unbuild": "^3.5.0",
    "vitest": "^3.0.0"
  }
}
