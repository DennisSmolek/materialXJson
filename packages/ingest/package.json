{
  "name": "@materialxjs/ingest",
  "version": "0.1.0",
  "description": "Ingest PBR materials from texture folders, zips, or .mtlx files into MtlxDocument",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "unbuild",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "materialx",
    "pbr",
    "textures",
    "materials",
    "ingest"
  ],
  "author": "Dennis Smolek <dennis@smolek.dev> (https://smolek.dev)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DennisSmolek/materialXJson.git",
    "directory": "packages/ingest"
  },
  "homepage": "https://github.com/DennisSmolek/materialXJson/tree/main/packages/ingest#readme",
  "bugs": "https://github.com/DennisSmolek/materialXJson/issues",
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "dependencies": {
    "@materialxjs/json": "workspace:*",
    "@materialxjs/texture-map": "workspace:*",
    "fflate": "^0.8.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.7.0",
    "unbuild": "^3.5.0",
    "vitest": "^3.0.0"
  }
}
