{
  "name": "@materialxjs/cli",
  "version": "0.1.0",
  "description": "CLI for converting, inspecting, and creating MaterialX materials",
  "type": "module",
  "bin": {
    "materialxjs": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "unbuild",
    "dev": "tsx src/cli.ts",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "materialx",
    "cli",
    "gltf",
    "json"
  ],
  "author": "Dennis Smolek <dennis@smolek.dev> (https://smolek.dev)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DennisSmolek/materialXJson.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/DennisSmolek/materialXJson/tree/main/packages/cli#readme",
  "bugs": "https://github.com/DennisSmolek/materialXJson/issues",
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "dependencies": {
    "@materialxjs/gltf-pack": "workspace:*",
    "@materialxjs/ingest": "workspace:*",
    "@materialxjs/json": "workspace:*",
    "@materialxjs/texture-map": "workspace:*",
    "citty": "^0.1.6",
    "consola": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "fflate": "^0.8.2",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "unbuild": "^3.5.0",
    "vitest": "^3.2.4"
  }
}
